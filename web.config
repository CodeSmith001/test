<?xml version="1.0" encoding="UTF-8"?>
<!--
    SecureApp - قواعد الأمان لخادم IIS
    للاستخدام مع Windows Server / IIS
-->
<configuration>
    <system.webServer>
        
        <!-- منع عرض المجلدات -->
        <directoryBrowse enabled="false" />
        
        <!-- منع الوصول لملفات محددة -->
        <security>
            <requestFiltering>
                <denyUrlSequences>
                    <add sequence=".." />
                    <add sequence="config.php" />
                    <add sequence="functions.php" />
                    <add sequence="install.sql" />
                </denyUrlSequences>
                <fileExtensions>
                    <add fileExtension=".sql" allowed="false" />
                    <add fileExtension=".log" allowed="false" />
                </fileExtensions>
                <verbs>
                    <add verb="OPTIONS" allowed="false" />
                    <add verb="TRACE" allowed="false" />
                    <add verb="TRACK" allowed="false" />
                </verbs>
                <!-- منع الـ Query strings الضارة -->
                <queryStrings>
                    <add queryString="exec" allowed="false" />
                    <add queryString="system" allowed="false" />
                    <add queryString="passthru" allowed="false" />
                    <add queryString="shell_exec" allowed="false" />
                    <add queryString="eval" allowed="false" />
                    <add queryString="base64_decode" allowed="false" />
                </queryStrings>
            </requestFiltering>
        </security>
        
        <!-- هيدرات الأمان -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="X-XSS-Protection" value="1; mode=block" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
            </customHeaders>
        </httpProtocol>
        
        <!-- منع الوصول لمجلد uploads -->
        <location path="uploads">
            <system.webServer>
                <handlers>
                    <clear />
                </handlers>
            </system.webServer>
        </location>
        
        <!-- إعادة التوجيه إلى HTTPS -->
        <rewrite>
            <rules>
                <rule name="Force HTTPS" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="off" />
                        <add input="{HTTP_HOST}" pattern="^(localhost|127\.0\.0\.1)$" negate="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>
            </rules>
        </rewrite>
        
    </system.webServer>
</configuration>
